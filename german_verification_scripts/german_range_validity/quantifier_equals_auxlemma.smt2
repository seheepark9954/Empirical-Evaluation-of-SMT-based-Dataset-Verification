; =============================================================
; Range validity (duration) equivalence check: baseline vs aux lemma
; M = 1000, column index = 1, range: [0, 600)
; =============================================================

(define-fun duration_min () Int 0)
(define-fun duration_max () Int 600)

; ---- Baseline (quantifier style, but no forall) ----
(define-fun baseline_ok () Bool
  (not
    (exists ((i Int))
      (and (>= i 0) (< i m)
           (or (< (select (select D i) 1) duration_min)
               (>= (select (select D i) 1) duration_max))
      )
    )
  )
)

