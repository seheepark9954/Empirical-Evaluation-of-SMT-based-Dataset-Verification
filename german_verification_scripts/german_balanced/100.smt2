(assert (= (select L 0) 1))
(assert (= (select L 1) 2))

(define-fun-rec sum-if-value ((A (Array Int Int)) (item Int) (size Int)) Int
  (ite (< size 0)
       0
       (ite (= (select A size) item)
            (+ 1 (sum-if-value A item (- size 1)))
            (sum-if-value A item (- size 1))
       )
  )
)

(define-fun B () Int 2)

(assert
