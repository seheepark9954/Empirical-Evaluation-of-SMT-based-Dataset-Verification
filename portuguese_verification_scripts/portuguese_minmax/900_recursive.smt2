; ===== bounds for original Portuguese duration values =====
(define-fun min () Int 0)
(define-fun max () Int 6000)

; ===== recursive min-max validity on original Portuguese duration =====
(define-fun-rec minmax-ok ((i Int)) Bool
  (ite (< i 0)
       true
       (and
         (>= (select (select D i) 0) min)
         (<= (select (select D i) 0) max)
         (minmax-ok (- i 1))
       )
  )
)

