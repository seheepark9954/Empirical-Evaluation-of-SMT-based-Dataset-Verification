; =====================
; Distance threshold
; d = 0.2  → d² = 0.04
; =====================
(define-fun d2 () Real 4.0)

; =====================
; Squared Euclidean distance
; =====================
(define-fun-rec squared-diff-sum
  ((p1 (Array Int Real)) (p2 (Array Int Real)) (k Int)) Real
  (ite (< k 0)
       0.0
       (+ (* (- (select p1 k) (select p2 k))
             (- (select p1 k) (select p2 k)))
          (squared-diff-sum p1 p2 (- k 1)))
  )
)
; =====================





; =====================
; Auxiliary lemmas: well-distributedness (1D)
; =====================

(define-fun sqdist ((p Real) (i Int)) Real
  (* (- p (select (select D i) 0))
     (- p (select (select D i) 0)))
)

(define-fun close_p0 () Bool
  (or
    (<= (sqdist -1.0 0) d2)
